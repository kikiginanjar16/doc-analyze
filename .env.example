# OpenAI
OPENAI_API_KEY=your_key_here
OPENAI_MODEL_TEXT=gpt-4.1-mini
OPENAI_MODEL_VISION=gpt-4.1-mini

# Analyzer defaults
MAX_PAGES_DEFAULT=10
MAX_SLIDES_DEFAULT=20
SCAN_TEXT_THRESHOLD=200
REQUEST_TIMEOUT_SECONDS=120

# Optional PostgreSQL persistence
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/doc_analyzer

# Optional webhook delivery retry
WEBHOOK_TIMEOUT_SECONDS=15
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_BACKOFF_SECONDS=2
